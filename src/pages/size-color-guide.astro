---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Balloon Size & Color Guide | Balloon Hut Austin"
  description="Plan your event with our balloon size and color guide. Compare standard, pearl, and chrome balloon finishes to build your perfect custom decor in Austin, TX."
  keywords="balloon colors, balloon sizes, custom balloons Austin, chrome balloons, balloon finish guide, balloon order planning"
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-bg">
      <img src="/assets/arch-pretty-pink.jpg" alt="Beautiful Pink Balloon Arch" loading="lazy" />
      <div class="page-hero-overlay"></div>
    </div>
    <div class="container page-hero-content">
      <span class="page-hero-eyebrow">📏 Plan Like a Pro</span>
      <h1>Size & Color <span class="text-gradient-warm">Guide</span></h1>
      <p>Use this tool to discover the perfect dimensions and balloon finishes for your next memorable event.</p>
    </div>
  </section>

  <!-- Size Guide Block -->
  <section class="section size-section bg-light">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">Dimensions</span>
        <h2 class="section-title">Balloon <span class="text-gradient">Size Guide</span></h2>
        <p class="section-subtitle">How to estimate the size you need for your space</p>
      </div>

      <div class="size-grid">
        <div class="size-card card reveal reveal-delay-1">
          <div class="size-illustration">
            <div class="box box-small"></div>
            <div class="person-scale">🧍</div>
          </div>
          <h3>6-8 Foot (Columns/Towers)</h3>
          <p>Perfect for marking entryways, flanking a cake table, or spotlighting a guest of honor. Standard ceilings are 8-9 feet tall, so these fit perfectly indoors without touching the ceiling.</p>
        </div>

        <div class="size-card card reveal reveal-delay-2">
          <div class="size-illustration">
            <div class="box box-med"></div>
            <div class="person-scale">🧍</div>
          </div>
          <h3>10-12 Foot (Standard Arch)</h3>
          <p>The classic size. Fits perfectly over a single doorway or a standard 6-foot rectangular dessert table. This creates a cohesive "frame" for your primary photo op.</p>
        </div>

        <div class="size-card card reveal reveal-delay-3">
          <div class="size-illustration">
            <div class="box box-large"></div>
            <div class="person-scale">🧍</div>
          </div>
          <h3>20-24 Foot (Mega Arch)</h3>
          <p>Made for making a massive statement! These are needed to span a two-car driveway, span over double-doors, or cover a large stage backing at a corporate event.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Color Guide Block -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">Aesthetics</span>
        <h2 class="section-title">Balloon <span class="text-gradient">Finishes</span></h2>
        <p class="section-subtitle">The texture and shine of your balloons drastically changes the vibe of your event</p>
      </div>

      <div class="finish-grid">
        <!-- Standard -->
        <div class="finish-card card reveal">
          <div class="finish-swatches">
            <div class="swatch swatch-standard-1"></div>
            <div class="swatch swatch-standard-2"></div>
            <div class="swatch swatch-standard-3"></div>
          </div>
          <h3>Standard / Matte</h3>
          <p>Solid, opaque colors with no shine. This creates a modern, highly-pigmented look that is extremely popular for trendy, high-end organic arches and chic baby showers.</p>
        </div>

        <!-- Pearl -->
        <div class="finish-card card reveal reveal-delay-1">
          <div class="finish-swatches">
            <div class="swatch swatch-pearl-1"></div>
            <div class="swatch swatch-pearl-2"></div>
            <div class="swatch swatch-pearl-3"></div>
          </div>
          <h3>Pearl / Pastel</h3>
          <p>A soft, slightly iridescent finish that reflects light gently. Elegant and classic, this is the go-to finish for classical weddings, bridal showers, and elegant galas.</p>
        </div>

        <!-- Metallic/Chrome -->
        <div class="finish-card card reveal reveal-delay-2">
          <div class="finish-swatches">
            <div class="swatch swatch-chrome-1"></div>
            <div class="swatch swatch-chrome-2"></div>
            <div class="swatch swatch-chrome-3"></div>
          </div>
          <h3>Metallic / Chrome</h3>
          <p>A highly reflective, mirror-like finish that looks like liquid metal. Perfect as an accent color (like Chrome Gold or Silver) to add luxury or for dynamic party vibes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark section page-cta">
    <div class="container text-center reveal">
      <h2>Found Your Perfect Mix? 🎈</h2>
      <p>Let us know what size and finishes catch your eye and we'll build a custom quote for your event!</p>
      <div class="page-cta-buttons">
        <a href="/contact/" class="btn btn-primary btn-large">📋 Build My Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { position: relative; min-height: 50vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .page-hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(180deg, rgba(26, 14, 62, 0.75) 0%, rgba(45, 27, 105, 0.9) 100%); }
  .page-hero-content { position: relative; z-index: 1; text-align: center; padding: 8rem 0 4rem; }
  .page-hero-eyebrow { display: inline-block; font-family: var(--font-heading); font-size: 1rem; font-weight: 600; color: var(--color-mint); margin-bottom: var(--spacing-sm); }
  .page-hero-content h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); color: var(--color-white); margin-bottom: var(--spacing-xs); }
  .page-hero-content p { font-size: 1.2rem; color: rgba(255, 255, 255, 0.8); max-width: 600px; margin: 0 auto; }

  /* Size Guide */
  .bg-light { background: rgba(108, 92, 231, 0.03); }
  .size-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-md); }
  .size-card { text-align: center; padding: var(--spacing-lg) var(--spacing-md); }
  
  .size-illustration {
    position: relative;
    height: 150px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    margin-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--color-text-light);
    padding-bottom: 5px;
  }
  
  .person-scale {
    font-size: 2.5rem;
    position: relative;
    z-index: 2;
    margin: 0 10px;
  }
  
  .box {
    border: 3px dashed var(--color-primary);
    border-radius: 100px 100px 0 0;
    position: relative;
    z-index: 1;
    background: rgba(255, 107, 157, 0.1);
  }
  
  .box-small { width: 40px; height: 90px; border-radius: 10px 10px 0 0; margin-bottom: 5px; } /* Column representation */
  .box-med { width: 120px; height: 110px; }
  .box-large { width: 180px; height: 140px; }

  .size-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--color-dark); }
  .size-card p { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.6; }

  /* Color Guide */
  .finish-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-lg); }
  .finish-card { padding: var(--spacing-lg); text-align: center; }
  
  .finish-swatches {
    display: flex;
    justify-content: center;
    gap: -10px;
    margin-bottom: var(--spacing-md);
  }
  
  .swatch {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 -10px;
    border: 3px solid var(--color-white);
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }
  
  /* Matte Colors */
  .swatch-standard-1 { background: #E74C3C; }
  .swatch-standard-2 { background: #3498DB; }
  .swatch-standard-3 { background: #F1C40F; }
  
  /* Pearl Colors (soft gradient) */
  .swatch-pearl-1 { background: radial-gradient(circle at 30% 30%, #fff, #ffb6c1); }
  .swatch-pearl-2 { background: radial-gradient(circle at 30% 30%, #fff, #add8e6); }
  .swatch-pearl-3 { background: radial-gradient(circle at 30% 30%, #fff, #e6e6fa); }
  
  /* Chrome Colors (metallic gradient) */
  .swatch-chrome-1 { background: radial-gradient(circle at 30% 30%, #fff 0%, #d4af37 30%, #aa8c2c 100%); }
  .swatch-chrome-2 { background: radial-gradient(circle at 30% 30%, #fff 0%, #c0c0c0 30%, #808080 100%); }
  .swatch-chrome-3 { background: radial-gradient(circle at 30% 30%, #fff 0%, #cd7f32 30%, #a0522d 100%); }

  .finish-card h3 { font-size: 1.3rem; margin-bottom: 0.8rem; }
  .finish-card p { font-size: 0.95rem; color: var(--color-text-light); }

  .page-cta { padding: var(--spacing-2xl) 0; }
  .page-cta h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); color: var(--color-white); margin-bottom: var(--spacing-sm); }
  .page-cta p { font-size: 1.1rem; color: rgba(255,255,255,0.75); max-width: 500px; margin: 0 auto var(--spacing-lg); }

  @media (max-width: 900px) {
    .size-grid, .finish-grid { grid-template-columns: 1fr; }
  }
</style>
