---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import musicalNote from '../assets/images/musical-note-sculpture.jpg';
import iceCreamSculptures from '../assets/images/ice-cream-soda-sculptures.jpg';
import aisdLetters from '../assets/images/aisd-balloon-letters.jpg';
import oscarSculpture from '../assets/images/oscar-sculpture.jpg';

const sculptureTypes = [
  {
    name: 'Character Sculptures',
    description: 'Bring beloved characters to life! From Minions to princesses, our balloon characters become the star of the show at themed parties.',
    emoji: '🧸',
  },
  {
    name: 'Musical & Artistic',
    description: 'Musical notes, paint palettes, cameras — we transform abstract ideas into stunning 3D balloon art that wows every guest.',
    emoji: '🎵',
  },
  {
    name: 'Giant Letters & Numbers',
    description: 'Spell out names, ages, initials, or messages up to 7 feet tall! Perfect for milestone birthdays, graduations, and branding.',
    emoji: '🔤',
  },
  {
    name: 'Themed Creations',
    description: 'Oscar statues for awards nights, ice cream sodas for retro parties, sports trophies for game days — if you can dream it, we build it!',
    emoji: '🏆',
  },
  {
    name: 'Food & Object Sculptures',
    description: 'Ice cream cones, cupcakes, champagne bottles — whimsical food-themed balloons that are almost good enough to eat!',
    emoji: '🍦',
  },
  {
    name: 'Centerpiece Sculptures',
    description: 'Tabletop-sized balloon sculptures that double as stunning centerpieces. Great for corporate events, galas, and dinner parties.',
    emoji: '🌟',
  },
];

const gallery = [
  { image: musicalNote, caption: 'Musical Note Balloon Sculpture' },
  { image: iceCreamSculptures, caption: 'Ice Cream Soda Sculptures for Teachers Appreciation' },
  { image: aisdLetters, caption: 'AISD Leadership 7\' Balloon Letters' },
  { image: oscarSculpture, caption: 'Custom Balloon Sculpture Design' },
];

const faqs = [
  {
    q: "How big can balloon sculptures be?",
    a: "Our sculptures range from tabletop centerpieces (2-3 feet) to massive 7-foot tall letters and life-size character replicas. Tell us your vision and we'll make it happen!",
  },
  {
    q: "How long do balloon sculptures last?",
    a: "Indoor sculptures typically last 3-5 days. We recommend scheduling delivery the day of or evening before your event for peak appearance.",
  },
  {
    q: "Can you create any shape or character?",
    a: "Absolutely! If you can dream it, we can do it. Send us a photo or sketch of your idea and we'll bring it to life in balloons.",
  },
];
---

<BaseLayout
  title="Balloon Sculptures Austin | Custom Characters, Letters & 3D Balloon Art"
  description="Custom balloon sculptures in Austin TX — giant letters, character art, musical notes, food sculptures & more. Up to 7 feet tall! Call Balloon Hut Austin at 512-785-7253."
  keywords="balloon sculptures Austin, custom balloon art, giant balloon letters, balloon characters Austin TX, 3D balloon art, balloon centerpieces, balloon artist Austin"
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-bg">
      <Image src={musicalNote} alt="Balloon Sculptures" width={1400} quality="mid" />
      <div class="page-hero-overlay"></div>
    </div>
    <div class="container page-hero-content">
      <span class="page-hero-eyebrow">🎨 Imagination Meets Balloons</span>
      <h1>Balloon <span class="text-gradient-warm">Sculptures</span></h1>
      <p>Custom 3D balloon art — from giant letters to life-size characters, if you can dream it, we can build it!</p>
    </div>
  </section>

  <!-- Sculpture Types -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">What We Create</span>
        <h2 class="section-title">Sculpture <span class="text-gradient">Styles</span></h2>
        <p class="section-subtitle">Every sculpture is custom-designed to match your theme, colors, and celebration</p>
      </div>

      <div class="types-grid">
        {sculptureTypes.map((type, index) => (
          <div class={`type-card card reveal reveal-delay-${(index % 4) + 1}`}>
            <span class="type-emoji">{type.emoji}</span>
            <h3>{type.name}</h3>
            <p>{type.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section gallery-section" id="gallery">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">Our Work</span>
        <h2 class="section-title">Sculpture <span class="text-gradient">Gallery</span></h2>
      </div>

      <div class="page-gallery">
        {gallery.map((item, index) => (
          <div class={`gallery-card reveal reveal-delay-${(index % 4) + 1}`}>
            <div class="gallery-card-img">
              <Image
                src={item.image}
                alt={item.caption}
                width={500}
                quality="mid"
                data-lightbox={item.image.src}
                data-caption={item.caption}
              />
            </div>
            <div class="gallery-card-info">
              <p>{item.caption}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">Questions?</span>
        <h2 class="section-title">Sculpture <span class="text-gradient">FAQs</span></h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq, index) => (
          <div class={`faq-item card reveal reveal-delay-${index + 1}`}>
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark section page-cta">
    <div class="container text-center reveal">
      <h2>Have a Sculpture Idea? 🎨</h2>
      <p>Send us a photo, sketch, or description — we'll bring your balloon sculpture vision to life!</p>
      <div class="page-cta-buttons">
        <a href="tel:5127857253" class="btn btn-primary btn-large">📞 Call 512-785-7253</a>
        <a href="/contact/" class="btn btn-secondary btn-large">📋 Get a Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { position: relative; min-height: 50vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .page-hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(180deg, rgba(26, 14, 62, 0.7) 0%, rgba(45, 27, 105, 0.85) 100%); }
  .page-hero-content { position: relative; z-index: 1; text-align: center; padding: 8rem 0 4rem; }
  .page-hero-eyebrow { display: inline-block; font-family: var(--font-heading); font-size: 1rem; font-weight: 600; color: var(--color-accent); margin-bottom: var(--spacing-sm); }
  .page-hero-content h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); color: var(--color-white); margin-bottom: var(--spacing-xs); }
  .page-hero-content p { font-size: 1.2rem; color: rgba(255, 255, 255, 0.8); max-width: 600px; margin: 0 auto; }

  .types-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-md); }
  .type-card { padding: var(--spacing-lg); text-align: center; }
  .type-emoji { font-size: 3rem; display: block; margin-bottom: var(--spacing-sm); transition: transform var(--transition-bounce); }
  .type-card:hover .type-emoji { transform: scale(1.2) rotate(15deg); }
  .type-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; }
  .type-card p { font-size: 0.95rem; color: var(--color-text-light); }

  .page-gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--spacing-md); }
  .gallery-card { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); transition: all var(--transition-smooth); background: var(--color-white); }
  .gallery-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
  .gallery-card-img { position: relative; aspect-ratio: 4/3; overflow: hidden; cursor: pointer; }
  .gallery-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .gallery-card:hover .gallery-card-img img { transform: scale(1.08); }
  .gallery-card-info { padding: var(--spacing-sm) var(--spacing-md); }
  .gallery-card-info p { font-family: var(--font-heading); font-size: 0.95rem; font-weight: 500; color: var(--color-text); }

  .faq-list { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--spacing-sm); }
  .faq-item { padding: var(--spacing-md) var(--spacing-lg); }
  .faq-item h3 { font-size: 1.15rem; margin-bottom: 0.5rem; color: var(--color-primary); }
  .faq-item p { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.7; }

  .page-cta { padding: var(--spacing-2xl) 0; }
  .page-cta h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); color: var(--color-white); margin-bottom: var(--spacing-sm); }
  .page-cta p { font-size: 1.1rem; color: rgba(255,255,255,0.75); max-width: 500px; margin: 0 auto var(--spacing-lg); }
  .page-cta-buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; }

  @media (max-width: 900px) {
    .types-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .types-grid { grid-template-columns: 1fr; }
    .page-gallery { grid-template-columns: 1fr; }
    .page-cta-buttons { flex-direction: column; align-items: center; }
  }
</style>
