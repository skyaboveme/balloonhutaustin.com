---
import BaseLayout from '../layouts/BaseLayout.astro';
const eventDecor1 = '/assets/event-decor-1.jpg';
const eventDecor2 = '/assets/event-decor-2.jpg';
const eventDecor3 = '/assets/event-decor-3.jpg';
const eventDecor5 = '/assets/event-decor-5.jpg';

const dropTypes = [
  {
    name: 'Ceiling Drops',
    description: 'The ultimate party moment! Hundreds of balloons cascade from the ceiling at your signal — perfect for midnight countdowns, reveals, and grand finales.',
    emoji: '🎊',
    popular: true,
  },
  {
    name: 'Net Drops',
    description: 'Balloons are held in a net on the ceiling and released all at once for a dramatic cascade effect. Great for large venues and dance floors.',
    emoji: '🕸️',
    popular: false,
  },
  {
    name: 'Outdoor Releases',
    description: 'A magical moment where balloons are released into the sky for celebrations, memorials, and grand openings. We use eco-friendly biodegradable balloons.',
    emoji: '🌤️',
    popular: false,
  },
  {
    name: 'Confetti Balloon Pops',
    description: 'Giant balloons filled with confetti — pop them for a dazzling confetti explosion! Perfect for gender reveals, announcements, and photo ops.',
    emoji: '💥',
    popular: true,
  },
  {
    name: 'Stage Drops',
    description: 'Timed drops from above the stage for performances, award reveals, and corporate presentations. We coordinate with your event timeline.',
    emoji: '🎤',
    popular: false,
  },
  {
    name: 'Surprise Reveals',
    description: 'Gender reveals, promotion announcements, engagement surprises — we build the moment and make the reveal unforgettable!',
    emoji: '🎉',
    popular: true,
  },
];

const howItWorks = [
  {
    step: '1',
    title: 'Tell Us Your Vision',
    description: 'Call or email us with your event details — date, venue, number of guests, and the moment you want to make special.',
    emoji: '💬',
  },
  {
    step: '2',
    title: 'We Plan the Magic',
    description: 'We design the perfect drop or release — calculating the number of balloons, rigging, and timing for maximum impact.',
    emoji: '📐',
  },
  {
    step: '3',
    title: 'Setup & Rigging',
    description: 'Our team arrives early to rig the drop above your event space — nets, bags, or ceiling mounts depending on your venue.',
    emoji: '🔧',
  },
  {
    step: '4',
    title: 'The Big Moment!',
    description: 'When the time comes, we trigger the drop and hundreds of balloons cascade down — creating a moment your guests will never forget!',
    emoji: '🎊',
  },
];

const gallery = [
  { image: eventDecor1, caption: 'Balloon Drop Setup for Grand Celebration' },
  { image: eventDecor2, caption: 'Ceiling Net Drop Installation' },
  { image: eventDecor3, caption: 'Confetti Balloon Pop moment' },
  { image: eventDecor5, caption: 'Stage Drop During Event' },
];
---

<BaseLayout
  title="Balloon Drops & Releases Austin | Ceiling Drops, Confetti Pops & Reveals"
  description="Dramatic balloon drops and releases in Austin TX. Ceiling drops, net releases, confetti pops, gender reveals, and grand openings. Best prices in Central Texas! Call 512-785-7253."
  keywords="balloon drops Austin, balloon release Austin, ceiling balloon drop, confetti balloon pop, gender reveal balloons Austin TX, balloon release event, party balloon drop"
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="page-hero-bg">
      <img src={eventDecor2} alt="Balloon Drops and Releases" />
      <div class="page-hero-overlay"></div>
    </div>
    <div class="container page-hero-content">
      <span class="page-hero-eyebrow">🎊 The Ultimate Party Moment</span>
      <h1>Drops & <span class="text-gradient-warm">Releases</span></h1>
      <p>Create the most dramatic, unforgettable moment of your event with balloon drops and releases</p>
    </div>
  </section>

  <!-- Drop Types -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">Our Options</span>
        <h2 class="section-title">Drop & Release <span class="text-gradient">Styles</span></h2>
        <p class="section-subtitle">From ceiling cascades to confetti pops — choose the perfect dramatic moment</p>
      </div>

      <div class="drops-grid">
        {dropTypes.map((type, index) => (
          <div class={`drop-card card reveal reveal-delay-${(index % 4) + 1}`}>
            {type.popular && <span class="popular-badge">🔥 Popular</span>}
            <span class="drop-emoji">{type.emoji}</span>
            <h3>{type.name}</h3>
            <p>{type.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section-dark section how-section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow" style="color: var(--color-accent);">The Process</span>
        <h2 class="section-title" style="color: var(--color-white);">How It <span class="text-gradient-warm">Works</span></h2>
      </div>

      <div class="steps-grid reveal">
        {howItWorks.map((step) => (
          <div class="step-card">
            <div class="step-number">{step.step}</div>
            <span class="step-emoji">{step.emoji}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section gallery-section" id="gallery">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-eyebrow">Portfolio</span>
        <h2 class="section-title">Drops & Releases <span class="text-gradient">Gallery</span></h2>
      </div>

      <div class="page-gallery">
        {gallery.map((item, index) => (
          <div class={`gallery-card reveal reveal-delay-${(index % 4) + 1}`}>
            <div class="gallery-card-img">
              <img                 src={item.image}
                alt={item.caption}
                data-lightbox={item.image}
                data-caption={item.caption}
              />
            </div>
            <div class="gallery-card-info">
              <p>{item.caption}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark section page-cta">
    <div class="container text-center reveal">
      <h2>Ready for the Big Drop? 🎊</h2>
      <p>Our team handles everything — from rigging to the dramatic release. Call us to plan your unforgettable moment!</p>
      <div class="page-cta-buttons">
        <a href="tel:5127857253" class="btn btn-primary btn-large">📞 Call 512-785-7253</a>
        <a href="mailto:BalloonHutAustin@Gmail.com" class="btn btn-accent btn-large">✉️ Email Us</a>
        <a href="/contact/" class="btn btn-secondary btn-large">📋 Get a Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { position: relative; min-height: 50vh; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .page-hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .page-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(180deg, rgba(26, 14, 62, 0.7) 0%, rgba(45, 27, 105, 0.85) 100%); }
  .page-hero-content { position: relative; z-index: 1; text-align: center; padding: 8rem 0 4rem; }
  .page-hero-eyebrow { display: inline-block; font-family: var(--font-heading); font-size: 1rem; font-weight: 600; color: var(--color-accent); margin-bottom: var(--spacing-sm); }
  .page-hero-content h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); color: var(--color-white); margin-bottom: var(--spacing-xs); }
  .page-hero-content p { font-size: 1.2rem; color: rgba(255, 255, 255, 0.8); max-width: 600px; margin: 0 auto; }

  /* Drops Grid */
  .drops-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-md); }
  .drop-card { padding: var(--spacing-lg); text-align: center; position: relative; overflow: hidden; }
  .popular-badge { position: absolute; top: 1rem; right: 1rem; font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600; color: var(--color-primary); background: rgba(255, 107, 157, 0.1); padding: 0.3rem 0.8rem; border-radius: var(--radius-full); }
  .drop-emoji { font-size: 3rem; display: block; margin-bottom: var(--spacing-sm); transition: transform var(--transition-bounce); }
  .drop-card:hover .drop-emoji { transform: scale(1.2) rotate(15deg); }
  .drop-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; }
  .drop-card p { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.7; }

  /* How It Works Steps */
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--spacing-md); position: relative; }
  .steps-grid::before { content: ''; position: absolute; top: 60px; left: 12.5%; right: 12.5%; height: 3px; background: linear-gradient(90deg, var(--color-primary), var(--color-accent), var(--color-pop-purple), var(--color-mint)); border-radius: 3px; opacity: 0.3; }
  .step-card { text-align: center; position: relative; z-index: 1; padding: var(--spacing-sm); }
  .step-number { width: 44px; height: 44px; background: var(--gradient-warm); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-white); font-family: var(--font-heading); font-size: 1.2rem; font-weight: 700; margin: 0 auto var(--spacing-xs); box-shadow: 0 4px 15px rgba(255, 107, 157, 0.4); }
  .step-emoji { font-size: 2rem; display: block; margin-bottom: var(--spacing-xs); }
  .step-card h3 { font-size: 1.05rem; color: var(--color-accent); margin-bottom: 0.3rem; }
  .step-card p { font-size: 0.85rem; color: rgba(255,255,255,0.7); line-height: 1.6; }

  .page-gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--spacing-md); }
  .gallery-card { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); transition: all var(--transition-smooth); background: var(--color-white); }
  .gallery-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
  .gallery-card-img { position: relative; aspect-ratio: 16/10; overflow: hidden; cursor: pointer; }
  .gallery-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .gallery-card:hover .gallery-card-img img { transform: scale(1.08); }
  .gallery-card-info { padding: var(--spacing-sm) var(--spacing-md); }
  .gallery-card-info p { font-family: var(--font-heading); font-size: 0.95rem; font-weight: 500; color: var(--color-text); }

  .page-cta { padding: var(--spacing-2xl) 0; }
  .page-cta h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); color: var(--color-white); margin-bottom: var(--spacing-sm); }
  .page-cta p { font-size: 1.1rem; color: rgba(255,255,255,0.75); max-width: 550px; margin: 0 auto var(--spacing-lg); }
  .page-cta-buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; }

  @media (max-width: 900px) {
    .drops-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid::before { display: none; }
  }
  @media (max-width: 600px) {
    .drops-grid { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .page-gallery { grid-template-columns: 1fr; }
    .page-cta-buttons { flex-direction: column; align-items: center; }
  }
</style>
